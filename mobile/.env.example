# Mobile app (Expo) — copy to `.env` (git-ignored). EXPO_PUBLIC_* values are
# embedded in the build and are PUBLIC. See ../docs/AUTH_SETUP.md.

# Backend base URL. Defaults to the production Pages deployment; point at a
# local `npm run dev:full` server when developing (use your machine's LAN IP
# for a physical device, or http://localhost:8788 for the iOS simulator).
EXPO_PUBLIC_API_URL=

# Force the dev "pick any user" login in a release build. Dev login is always
# on in Expo dev (__DEV__). Leave unset for production.
EXPO_PUBLIC_DEV_LOGIN=

# NOTE: Google OAuth client ids live in app.json -> expo.extra
# (googleWebClientId / googleIosClientId / googleAndroidClientId), not here.
# Apple native sign-in uses the iOS bundle id (com.ppclub.app) as its audience.
