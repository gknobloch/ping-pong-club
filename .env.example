# Web app (Vite) — copy to `.env.local` (git-ignored) for local dev, and set the
# same VITE_* names as build env vars on Cloudflare Pages for production.
# VITE_* values are baked into the client bundle at build time and are PUBLIC.
# See docs/AUTH_SETUP.md.

# Google OAuth — the *web* OAuth client id (Google Identity Services).
VITE_GOOGLE_CLIENT_ID=

# Apple OAuth — the *web* Service ID (NOT the native app bundle id).
VITE_APPLE_CLIENT_ID=
# Redirect URI registered on that Service ID. Defaults to `${origin}/login`.
VITE_APPLE_REDIRECT_URI=

# Force the dev "pick any user" login in a production build (e.g. for a staging
# preview). Leave unset in real production. Dev login is always on in `vite dev`.
VITE_DEV_LOGIN=
